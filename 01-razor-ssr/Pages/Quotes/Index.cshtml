@page "/Quotes"
@model QuotesApp.Pages.Quotes.IndexModel
@{
    ViewData["Title"] = "Quotes";
}

<div id="page">

<h1 class="mb-6 text-2xl font-semibold text-slate-900">Quotes</h1>

<div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
    <table class="w-full text-left text-sm">
        <thead class="border-b border-slate-200 bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
            <tr>
                <th class="px-4 py-3">Reference</th>
                <th class="px-4 py-3">Client</th>
                <th class="px-4 py-3 text-right">Amount</th>
                <th class="px-4 py-3">Status</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            @foreach (var quote in Model.Quotes)
            {
                <tr x-data @@click="$event.target.closest('a') || $el.querySelector('a').click()" class="cursor-pointer hover:bg-slate-50">
                    <td class="px-4 py-3">
                        <a href="/Quotes/@quote.Id" x-target.push="page" class="font-medium text-[#6B3D5A] hover:underline">@quote.Reference</a>
                    </td>
                    <td class="px-4 py-3">
                        <div>@quote.ClientName</div>
                        <div class="text-xs text-slate-400">@quote.PropertyAddress</div>
                    </td>
                    <td class="px-4 py-3 text-right tabular-nums">£@quote.Amount.ToString("N0")</td>
                    <td class="px-4 py-3">
                        <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600">@quote.Status</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

</div>
