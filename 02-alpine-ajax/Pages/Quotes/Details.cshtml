@page "/Quotes/{id:int}"
@model QuotesApp.Pages.Quotes.DetailsModel
@{
    ViewData["Title"] = Model.Quote.Reference;
}

<div id="page">

<a href="/Quotes" x-target.push="page" class="mb-4 inline-block text-sm text-[#6B3D5A] hover:underline">&larr; All quotes</a>

<div class="grid grid-cols-1 gap-6 md:grid-cols-3">

    <!-- LEFT: quote + notes (wider) -->
    <div class="md:col-span-2 space-y-6">

        <section class="rounded-lg border border-slate-200 bg-white p-6">
            <div class="flex items-baseline justify-between">
                <h1 class="text-2xl font-semibold text-slate-900">@Model.Quote.Reference</h1>
                <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600">@Model.Quote.Status</span>
            </div>
            <dl class="mt-4 grid grid-cols-2 gap-y-2 text-sm">
                <dt class="text-slate-500">Client</dt>
                <dd class="text-right font-medium">@Model.Quote.ClientName</dd>
                <dt class="text-slate-500">Property</dt>
                <dd class="text-right font-medium">@Model.Quote.PropertyAddress</dd>
                <dt class="text-slate-500">Amount</dt>
                <dd class="text-right font-medium tabular-nums">£@Model.Quote.Amount.ToString("N0")</dd>
            </dl>
        </section>

        <section class="rounded-lg border border-slate-200 bg-white p-6">
            <h2 class="mb-4 text-lg font-semibold text-slate-900">Notes</h2>

            <ul id="notes" class="space-y-3">
                @foreach (var note in Model.Quote.Notes)
                {
                    <li id="note-@note.Id" class="rounded-md border border-slate-200 p-3">
                        @if (Model.EditNoteId == note.Id)
                        {
                            <form method="post" asp-page-handler="EditNote" asp-route-id="@Model.Quote.Id" asp-route-noteId="@note.Id" x-target="note-@note.Id" class="space-y-2">
                                <textarea name="Input.Body" rows="2" x-autofocus class="w-full rounded-md border border-slate-300 p-2 text-sm">@note.Body</textarea>
                                <span asp-validation-for="Input.Body" class="block text-sm text-red-600"></span>
                                <div class="flex gap-2">
                                    <button type="submit" class="rounded-md bg-[#6B3D5A] px-3 py-1.5 text-sm font-medium text-white hover:bg-[#44243A]">Save</button>
                                    <a href="/Quotes/@Model.Quote.Id" x-target="note-@note.Id" class="rounded-md px-3 py-1.5 text-sm text-slate-600 hover:bg-slate-100">Cancel</a>
                                </div>
                            </form>
                        }
                        else
                        {
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <p class="text-sm text-slate-800">@note.Body</p>
                                    <p class="mt-1 text-xs text-slate-400">@note.CreatedAt.ToString("d MMM, HH:mm")</p>
                                </div>
                                <div class="flex shrink-0 items-center gap-3">
                                    <a href="/Quotes/@Model.Quote.Id?editNote=@note.Id" x-target="note-@note.Id" aria-label="Edit" title="Edit" class="text-[#6B3D5A] hover:text-[#44243A]">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" /></svg>
                                    </a>
                                    <form method="post" asp-page-handler="DeleteNote" asp-route-id="@Model.Quote.Id" asp-route-noteId="@note.Id" x-target="notes" x-on:ajax:before="confirm('Delete this note?') || $event.preventDefault()">
                                        <button type="submit" aria-label="Delete" title="Delete" class="text-red-600 hover:text-red-700">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.158-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.043-2.09 1.02-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" /></svg>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </li>
                }
            </ul>

            @if (Model.Quote.Notes.Count == 0)
            {
                <p class="text-sm text-slate-400">No notes yet.</p>
            }

            <form id="note-form" method="post" asp-page-handler="AddNote" asp-route-id="@Model.Quote.Id" x-target="notes note-form" class="mt-5 space-y-2 border-t border-slate-100 pt-5">
                <textarea asp-for="Input.Body" rows="2" placeholder="Add a note…" class="w-full rounded-md border border-slate-300 p-2 text-sm"></textarea>
                @if (Model.EditNoteId is null)
                {
                    <span asp-validation-for="Input.Body" class="block text-sm text-red-600"></span>
                }
                <button type="submit" class="rounded-md bg-[#6B3D5A] px-4 py-2 text-sm font-medium text-white hover:bg-[#44243A]">Add note</button>
            </form>
        </section>
    </div>

    <!-- RIGHT: summary (narrower) -->
    <div class="space-y-6">
        <section class="rounded-lg border border-slate-200 bg-white p-6 text-center">
            <div id="count" x-sync class="text-3xl font-semibold text-slate-900">@Model.Quote.Notes.Count</div>
            <div class="text-sm text-slate-500">notes</div>
        </section>

        <section x-init @@note:changed.window="$ajax('/Quotes/@Model.Quote.Id', { target: 'activity' })"
                 class="rounded-lg border border-slate-200 bg-white p-6">
            <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-slate-500">Recent activity</h2>
            <ul id="activity" class="space-y-2 text-sm">
                @foreach (var activity in Model.Quote.Activities.OrderByDescending(a => a.Timestamp).Take(6))
                {
                    var badge = activity.Kind switch
                    {
                        ActivityKind.Added   => "bg-green-100 text-green-700",
                        ActivityKind.Edited  => "bg-amber-100 text-amber-700",
                        ActivityKind.Deleted => "bg-red-100 text-red-700",
                        _ => "bg-slate-100 text-slate-600"
                    };
                    var iconPath = activity.Kind switch
                    {
                        ActivityKind.Added   => "M12 4.5v15m7.5-7.5h-15",
                        ActivityKind.Edited  => "m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125",
                        ActivityKind.Deleted => "M6 18 18 6M6 6l12 12",
                        _ => "M12 4.5v15m7.5-7.5h-15"
                    };
                    <li class="flex items-center justify-between gap-2">
                        <span class="flex items-center gap-2">
                            <span class="inline-flex h-5 w-5 items-center justify-center rounded-full @badge">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="h-3 w-3"><path stroke-linecap="round" stroke-linejoin="round" d="@iconPath" /></svg>
                            </span>
                            <span class="text-slate-700">@activity.Description</span>
                        </span>
                        <span class="shrink-0 text-xs text-slate-400">@TimeAgo.From(activity.Timestamp)</span>
                    </li>
                }
                @if (Model.Quote.Activities.Count == 0)
                {
                    <li class="text-slate-400">Nothing yet.</li>
                }
            </ul>
        </section>
    </div>
</div>

</div>
